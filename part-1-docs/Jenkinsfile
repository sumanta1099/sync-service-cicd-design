pipeline {
    agent any

    environment {
        PROJECT_ID   = "sync-project"
        REGION       = "us-central1"
        SERVICE_NAME = "sync-service"
        REPOSITORY   = "backend"

        IMAGE_TAG = "${BUILD_NUMBER}"

        IMAGE = "${REGION}-docker.pkg.dev/${PROJECT_ID}/${REPOSITORY}/${SERVICE_NAME}:${IMAGE_TAG}"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: "${BRANCH_NAME}",
                url: 'https://github.com/company/sync-service.git'
            }
        }

        stage('Build') {
            steps {
                sh './mvnw clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                sh './mvnw test'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t ${IMAGE} .
                """
            }
        }

        stage('Push Docker Image') {
            when {
                anyOf {
                    branch 'development'
                    branch 'staging'
                    branch 'prod'
                }
            }

            steps {
                sh """
                gcloud auth configure-docker ${REGION}-docker.pkg.dev -q
                docker push ${IMAGE}
                """
            }
        }

        stage('Production Approval') {
            when {
                branch 'prod'
            }

            steps {
                input message: "Approve Production Deployment?"
            }
        }

        stage('Deploy to Cloud Run') {
            when {
                anyOf {
                    branch 'development'
                    branch 'staging'
                    branch 'prod'
                }
            }

            steps {

                script {

                    def profile = "qa"

                    if (env.BRANCH_NAME == "staging") {
                        profile = "staging"
                    }

                    if (env.BRANCH_NAME == "prod") {
                        profile = "prod"
                    }

                    sh """
                    gcloud run deploy ${SERVICE_NAME} \
                      --image ${IMAGE} \
                      --region ${REGION} \
                      --platform managed \
                      --allow-unauthenticated \
                      --set-env-vars SPRING_PROFILES_ACTIVE=${profile}
                    """
                }
            }
        }

        stage('Health Check') {
            when {
                anyOf {
                    branch 'development'
                    branch 'staging'
                    branch 'prod'
                }
            }

            steps {
                sh """
                SERVICE_URL=\$(gcloud run services describe ${SERVICE_NAME} \
                  --region ${REGION} \
                  --format='value(status.url)')

                curl -f \$SERVICE_URL/actuator/health
                """
            }
        }
    }

    post {

        failure {

            echo "Deployment failed. Rolling back..."

            sh """
            PREVIOUS_REVISION=\$(gcloud run revisions list \
              --service=${SERVICE_NAME} \
              --region=${REGION} \
              --sort-by="~metadata.creationTimestamp" \
              --format="value(metadata.name)" | sed -n '2p')

            if [ ! -z "\$PREVIOUS_REVISION" ]; then

              gcloud run services update-traffic ${SERVICE_NAME} \
                --region=${REGION} \
                --to-revisions=\$PREVIOUS_REVISION=100

            else
              echo "No previous revision found."
            fi
            """
        }
    }
}