pipeline {
    agent any

    environment {
        APP_NAME = "sync-service"
        REGISTRY = "gcr.io/sync"
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: "${BRANCH_NAME}",
                url: 'https://github.com/company/sync-service.git'
            }
        }

        stage('Build') {
            steps {
                sh './mvnw clean package -DskipTests'
            }
        }

        stage('Unit Test') {
            steps {
                sh './mvnw test'
            }
        }

        stage('Code Quality') {
            steps {
                echo "Running SonarQube Scan"
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t $REGISTRY/$APP_NAME:$IMAGE_TAG .
                """
            }
        }

        stage('Push Docker Image') {
            when {
                anyOf {
                    branch 'development'
                    branch 'staging'
                    branch 'prod'
                }
            }

            steps {
                sh """
                docker push $REGISTRY/$APP_NAME:$IMAGE_TAG
                """
            }
        }

        stage('Deploy to QA') {
            when {
                branch 'development'
            }

            steps {
                sh """
                ssh qa-server '
                docker pull $REGISTRY/$APP_NAME:$IMAGE_TAG &&
                docker stop sync-service || true &&
                docker rm sync-service || true &&
                docker run -d \
                  --name sync-service \
                  -p 8080:8080 \
                  -e SPRING_PROFILES_ACTIVE=qa \
                  $REGISTRY/$APP_NAME:$IMAGE_TAG
                '
                """
            }
        }

        stage('Deploy to Staging') {
            when {
                branch 'staging'
            }

            steps {
                sh """
                ssh staging-server '
                docker pull $REGISTRY/$APP_NAME:$IMAGE_TAG &&
                docker stop sync-service || true &&
                docker rm sync-service || true &&
                docker run -d \
                  --name sync-service \
                  -p 8080:8080 \
                  -e SPRING_PROFILES_ACTIVE=staging \
                  $REGISTRY/$APP_NAME:$IMAGE_TAG
                '
                """
            }
        }

        stage('Production Approval') {
            when {
                branch 'prod'
            }

            steps {
                input message: "Approve Production Deployment?"
            }
        }

        stage('Deploy to Production') {
            when {
                branch 'prod'
            }

            steps {
                sh """
                ssh prod-server '
                docker pull $REGISTRY/$APP_NAME:$IMAGE_TAG &&
                docker stop sync-service || true &&
                docker rm sync-service || true &&
                docker run -d \
                  --name sync-service \
                  -p 8080:8080 \
                  -e SPRING_PROFILES_ACTIVE=prod \
                  $REGISTRY/$APP_NAME:$IMAGE_TAG
                '
                """
            }
        }

        stage('Health Check') {
            steps {
                sh """
                curl -f http://server-ip:8080/actuator/health
                """
            }
        }
    }

    post {
        failure {
            echo "Deployment failed. Starting rollback..."

            sh """
            ssh prod-server '
            docker pull $REGISTRY/$APP_NAME:previous-stable &&
            docker stop sync-service || true &&
            docker rm sync-service || true &&
            docker run -d \
              --name sync-service \
              -p 8080:8080 \
              $REGISTRY/$APP_NAME:previous-stable
            '
            """
        }
    }
}